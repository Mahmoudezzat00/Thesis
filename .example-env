
NEXT_PUBLIC_APP_NAME=SmartShop Thesis
NEXT_PUBLIC_APP_DESCRIPTION=An analytics-focused ecommerce thesis project built with Next.js, MongoDB, and Tailwind CSS
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Public HTTPS URL used in emails for product links and images.
# For local email testing, use a deployed URL or an HTTPS tunnel such as ngrok.
EMAIL_PUBLIC_BASE_URL=
# Optional separate public image base. Useful for local demos with seeded images:
# https://raw.githubusercontent.com/Mahmoudezzat00/Thesis/main/public
EMAIL_IMAGE_BASE_URL=

# Database
MONGODB_URI=mongodb://localhost/smartshop-thesis
 

# Auth
# Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=
# Google OAuth redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

RESEND_API_KEY=
SENDER_NAME=SmartShop Thesis
SENDER_EMAIL=
# Optional: while using onboarding@resend.dev, route all emails to the single
# recipient Resend allows before you verify a sending domain.
RESEND_DEMO_RECIPIENT=

# UPLOADTHING
UPLOADTHING_TOKEN=
# PAYPAL
PAYPAL_API_URL=
PAYPAL_CLIENT_ID=
PAYPAL_APP_SECRET=

# STRIPE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: only use for local/thesis demos. In development, demo payment
# confirmation is available automatically. Set to true only if a deployed demo
# must show mock Stripe/PayPal payment completion.
ENABLE_DEMO_PAYMENTS=
